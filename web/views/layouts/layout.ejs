<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= locals.title || 'ClubInfoTech' %></title>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600&family=Inter:wght@400;500&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <div id="globalLoader" class="global-loader" aria-hidden="true">
    <div class="global-loader-box" role="status" aria-live="polite">
      <span class="global-spinner" aria-hidden="true"></span>
      <span class="global-loader-text">Loading data...</span>
    </div>
  </div>
  <%- include('../partials/header', { activeTab: locals.activeTab || '' }) %>
  <main class="container">
    <%- body %>
  </main>
  <%- include('../partials/footer') %>
  <%- script || '' %>
  <script src="/js/main.js"></script>
</body>
</html>
